---
import { formatDate } from '@/utils';

interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
}

const { id, title, description, pubDate } = Astro.props;
const pubDateFmt = formatDate(pubDate);
---

<article>
  <div class="body">
    <a href={`/posts/${id}`}>{title}</a>
    <p>{description}</p>
  </div>
  <span class="date">{pubDateFmt}</span>
</article>

<style>
  article {
    align-items: start;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr 5.625rem;
    padding: 1.125rem 0;
  }

  a {
    border-bottom: 1px solid var(--accent);
    color: var(--accent);
    display: inline-block;
    font-weight: 600;
    margin-bottom: 0.25rem;
    text-decoration: none;
  }

  p {
    color: var(--fg-dim);
    margin-top: 0.25rem;
  }

  .date {
    color: var(--fg-muted);
    font-size: 0.6875rem;
    padding-top: 0.1875rem;
    text-align: right;
  }
</style>
